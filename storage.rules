rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Training videos — readable only by authenticated users,
    // writable by any authenticated user (admin gate enforced at app layer
    // for speed — avoids cross-service firestore.get() on every upload chunk).
    match /training-videos/{kind}/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 500 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // Training attachments (PDFs, images) — same auth model as videos.
    match /training-attachments/{kind}/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024  // 50MB per file
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    // Deny everything else by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
